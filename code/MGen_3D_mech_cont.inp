! resume,B2pF_3D,db
! ------------------------------------------------------
! - Define Contacts
! Coil pack, layer-1 - Coil radial insulation, layer-1
!*use,ContactPropMacro.mac,10,'conta174',0,3,mu_all,0e-6,110,'targe170'
*use,ContactPropMacro.mac,10,'conta174',0,1,mu_all,0e-6,110,'targe170'

! Coil radial insulation, layer-1 - Coil pack, layer-2
!*use,ContactPropMacro.mac,11,'conta174',0,3,mu_all,0e-6,111,'targe170'
*use,ContactPropMacro.mac,11,'conta174',0,1,mu_all,0e-6,111,'targe170'

! Coil pack, layer-2 - Coil radial insulation, layer-2
*use,ContactPropMacro.mac,12,'conta174',0,4,mu_all,0e-6,112,'targe170'
! *use,ContactPropMacro.mac,12,'conta174',5,1,mu_all,0e-6,112,'targe170'

! End spacer - Wedge
*use,ContactPropMacro.mac,13,'conta174',0,1,mu_all,0e-6,113,'targe170'

! Coil - Front / Can easily be separated from pole as I have separate pole/wedge surfaces
! Coil back side, layer-1 - Wedge front side, layer-1 (only for straight section)
*use,ContactPropMacro.mac,20,'conta174',0,3,mu_all,0e-6,120,'targe170'

! Coil front side, layer-1 - Wedge back side, layer-1 (only for straight section)
*use,ContactPropMacro.mac,21,'conta174',0,3,mu_all,0e-6,121,'targe170'

! Coil-1 back side, layer-1 - End spacer-1 front side, layer-1
*use,ContactPropMacro.mac,22,'conta174',0,3,mu_all,0e-6,122,'targe170'

! Coil-2 back side, layer-1 - End spacer-2 front side, layer-1
*use,ContactPropMacro.mac,23,'conta174',0,3,mu_all,0e-6,123,'targe170'

! Coil-3 back side, layer-1 - End spacer-3 front side, layer-1
*use,ContactPropMacro.mac,24,'conta174',0,3,mu_all,0e-6,124,'targe170'

! Coil-4 back side, layer-1 - End shoe front side, layer-1
*use,ContactPropMacro.mac,25,'conta174',0,3,mu_all,0e-6,125,'targe170'

! Coil, layer-1 - Pole tip, layer-1
*use,ContactPropMacro.mac,26,'conta174',0,3,mu_all,0e-6,126,'targe170'

! Coil-2 front side, layer-1 - End spacer-1 back side, layer-1
*use,ContactPropMacro.mac,27,'conta174',0,3,mu_all,0e-6,127,'targe170'

! Coil-3 front side, layer-1 - End spacer-2 back side, layer-1
*use,ContactPropMacro.mac,28,'conta174',0,3,mu_all,0e-6,128,'targe170'

! Coil-4 front side, layer-1 - End spacer-3 back side, layer-1
*use,ContactPropMacro.mac,29,'conta174',0,3,mu_all,0e-6,129,'targe170'

! Coil back side, layer-2 - Wedge front side, layer-2
*use,ContactPropMacro.mac,80,'conta174',0,3,mu_all,0e-6,180,'targe170'

! Coil front side, layer-2 - Wedge back side, layer-2
*use,ContactPropMacro.mac,81,'conta174',0,3,mu_all,0e-6,181,'targe170'

! Coil-1 back side, layer-2 - End spacer-1 front side, layer-2
*use,ContactPropMacro.mac,82,'conta174',0,3,mu_all,0e-6,182,'targe170'

! Coil-2 back side, layer-2 - End spacer-2 front side, layer-2
*use,ContactPropMacro.mac,83,'conta174',0,3,mu_all,0e-6,183,'targe170'

! Coil-3 back side, layer-2 - End spacer-3 front side, layer-2
*use,ContactPropMacro.mac,84,'conta174',0,3,mu_all,0e-6,184,'targe170'

! Coil-4 back side, layer-2 - End shoe front side, layer-2
*use,ContactPropMacro.mac,85,'conta174',0,3,mu_all,0e-6,185,'targe170'

! Coil, layer-2 - Pole tip, layer-2
*use,ContactPropMacro.mac,86,'conta174',0,3,mu_all,0e-6,186,'targe170'

! Coil-2 front side, layer-2 - End spacer-1 back side, layer-2
*use,ContactPropMacro.mac,87,'conta174',0,3,mu_all,0e-6,187,'targe170'

! Coil-3 front side, layer-2 - End spacer-2 back side, layer-2
*use,ContactPropMacro.mac,88,'conta174',0,3,mu_all,0e-6,188,'targe170'

! Coil-4 front side, layer-2 - End spacer-3 back side, layer-2
*use,ContactPropMacro.mac,89,'conta174',0,3,mu_all,0e-6,189,'targe170'

! coil 21 - coil 22 at straight section
*use,ContactPropMacro.mac,90,'conta174',0,3,mu_all,0e-6,190,'targe170'

! coil 23 - coil 24 at straight section
*use,ContactPropMacro.mac,91,'conta174',0,3,mu_all,0e-6,191,'targe170'

! Coil - Internal
! *use,ContactPropMacro.mac,31,'conta174',0,1,mu_all,0e-6,131,'targe170'

! Coil 1 - Pole 1
! *use,ContactPropMacro.mac,21,'conta174',0,1,mu_all,0e-6,121,'targe170'

! ! Coil 2 - Pole 2
! *use,ContactPropMacro.mac,22,'conta174',0,1,mu_all,0e-6,122,'targe170'

! ! Coil 1 - Wedge 1
! *use,ContactPropMacro.mac,31,'conta174',5,1,mu_all,0e-6,131,'targe170'

! ! Coil 2 - Wedge 2
! *use,ContactPropMacro.mac,32,'conta174',5,1,mu_all,0e-6,132,'targe170'
! ------------------------------------------------------
! Split coil-pole tip
*do,ll,1,Nlayer
	cmsel,s,poletip%ll%
	vgen,2,all, , , , , , , , 0
	cm,tmp,volu
	cmsel,s,poletip%ll%
	alls,below,volu
	vclear,all
	vdele,all, , , 1
	cmsel,s,tmp
	cm,poletip%ll%,volu
	cmdele,tmp
*enddo

! Split Coil-Wedge
*do,ll,1,Nlayer
	cmsel,s,wedge%ll%
	vgen,2,all, , , , , , , , 0
	cm,tmp,volu
	cmsel,s,wedge%ll%
	alls,below,volu
	vclear,all
	vdele,all, , , 1
	cmsel,s,tmp
	cm,wedge%ll%,volu
	cmdele,tmp
*enddo

! Split Coil-End spacer
*do,ll,1,Nlayer
	cmsel,s,espacer%ll%
	vgen,2,all, , , , , , , , 0
	cm,tmp,volu
	cmsel,s,espacer%ll%
	alls,below,volu
	vclear,all
	vdele,all, , , 1
	cmsel,s,tmp
	cm,espacer%ll%,volu
	cmdele,tmp
*enddo

! Split End-shoe
*do,ll,1,Nlayer
	cmsel,s,endshoe%ll%
	vgen,2,all, , , , , , , , 0
	cm,tmp,volu
	cmsel,s,endshoe%ll%
	alls,below,volu
	vclear,all
	vdele,all, , , 1
	cmsel,s,tmp
	cm,endshoe%ll%,volu
	cmdele,tmp
*enddo

! Split Coil
! *do,ll,1,Nlayer
! 	cmsel,s,coil%ll%
! 	vgen,2,all, , , , , , , , 0
! 	cm,tmp,volu
! 	cmsel,s,coil%ll%
! 	alls,below,volu
! 	vclear,all
! 	vdele,all, , , 1
! 	cmsel,s,tmp
! 	cm,coil%ll%,volu
! 	cmdele,tmp
! *enddo

cmsel,s,coil1
cmsel,a,wedge1
cmsel,a,poletip1
cmsel,a,espacer1
cmsel,a,endshoe1
cm,layer1,volu

cmsel,s,coil2
cmsel,a,wedge2
cmsel,a,poletip2
cmsel,a,espacer2
cmsel,a,endshoe2
cm,layer2,volu

cmsel,s,coil1
cmsel,a,coil2
cm,coil,volu
