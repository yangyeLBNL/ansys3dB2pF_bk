! named each coil front and back surface 
! layer-1
*do,i,1,4
 ! front side
 cmsel,s,coil1%i%
 allsel,below
 asel,u,loc,z,coil_length-end_length
 asel,u,loc,y,90
 asel,u,loc,z,0
 asel,u,loc,x,r11
 asel,u,loc,x,r12
 cm,acoil1%i%_all,area

 ! select the front surface
 cmsel,s,acoil1%i%_all
 allsel,below,area
 ksel,u,loc,y,90
 *get,ymax,kp,,mxloc,y
 ksel,r,loc,y,ymax
 lslk,r
 asll,r
 cm,acoil1%i%_front,area

 ! select the back surface
 cmsel,s,acoil1%i%_all
 cmsel,u,acoil1%i%_front
 cm,acoil1%i%_back,area
*enddo

! layer-2
*do,i,1,4
 ! select the surface at the inner radius
 cmsel,s,coil2%i%
 allsel,below,volu
 asel,r,loc,x,r21
 allsel,below,area
 *get,narea,area,0,count
 *if,narea,eq,2,then
  cm,tmp,area
 *else
  ksel,r,loc,z,0
  *get,ymax,kp,,mxloc,y
  cmsel,s,coil2%i%
  allsel,below,volu
  asel,r,loc,x,r21
  allsel,below,area
  ksel,r,loc,y,ymax
  lslk,r
  asll,r
  cm,tmp,area
 *endif

 ! all sides
 cmsel,s,coil2%i%
 allsel,below,volu
 asel,u,loc,z,coil_length-end_length
 asel,u,loc,y,90
 asel,u,loc,z,0
 ! using the selected area instead of selecting r21
 cmsel,u,tmp
 !asel,u,loc,x,r21
 asel,u,loc,x,r22
 cm,acoil2%i%_all,area
 
 ! front side
 cmsel,s,acoil2%i%_all
 allsel,below,area
 ksel,r,loc,z,0
 *get,ymax,kp,,mxloc,y
 cmsel,s,acoil2%i%_all
 allsel,below,area
 ksel,r,loc,y,ymax
 lslk,r
 asll,r
 cm,acoil2%i%_front,area

 ! back side
 cmsel,s,acoil2%i%_all
 cmsel,u,acoil2%i%_front
 allsel,below,area
 cm,acoil2%i%_back,area

*enddo

