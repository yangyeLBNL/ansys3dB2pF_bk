! Rod - nut
type,44

local,15,1,r_rod*cos(t_rod),r_rod*sin(t_rod),0

csys,15
real,44
mat ,44

! Generate the target surface
cmsel,s,nut
alls,below,volu
asel,r,loc,x,d_rod*0.5
nsla,s,1
esln,s,0
type,144
esurf,all
alls

! Generate the contact surface
cmsel,s,rod
alls,below,volu
asel,r,loc,x,d_rod*0.5
asel,r,loc,z,length+teplate,length+teplate+h_nut
nsla,s,1
esln,s,0
type,44
esurf,all
allsel

csys,0


