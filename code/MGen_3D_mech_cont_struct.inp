! ------------------------------------------------------
! - Notes
! For the moment, starting with wedge coupled with coil, will
! change later
! -----------------------------------------------------------------
! Real constant ans key option for the contact elements
! keyopt(12)=0 standard (separation - sliding)
! keyopt(12)=1 rough (separation - no sliding)
! keyopt(12)=2 no separation (sliding)
! keyopt(12)=5 bonded (no separation - no sliding)
! keyopt(9)=1 Exclude both initial penetration or gap
! keyopt(9)=0 Include both initial penetration or gap
! keyopt(9)=3 Include offset only (contact real constant, positive being interf), exclude both initial penetration or gap

! Parameters
! arg1 = Contact Element Number
! arg2 = Contact Element Name
! arg3 = Keyopt 12 Value
! arg4 = Keyopt 9 Value
! arg5 = Friction Coefficient Value
! arg6 = Real Constant 10 Value
! arg7 = Target Element Number
! arg8 = Target Element Type

! - Define Contacts
interf_collar = 0e-6

! Filler - Collar Top
*use,ContactPropMacro.mac,30,'conta174',0,1,mu_all,0e-6,130,'targe170'

! Collar_bot (upper) - collar_fil
*use,ContactPropMacro.mac,31,'conta174',0,4,mu_all,0e-6,131,'targe170'

! Filler - Collar Filler 
*use,ContactPropMacro.mac,32,'conta174',0,1,mu_all,0e-6,132,'targe170'

! Collar-top - Pad
*use,ContactPropMacro.mac,33,'conta174',0,1,mu_all,interf_collar,133,'targe170'

! Collar-bot - Pad
*use,ContactPropMacro.mac,34,'conta174',0,1,mu_all,interf_collar,134,'targe170'

! Yoke - Shell
*use,ContactPropMacro.mac,35,'conta174',0,1,mu_all,0e-6,135,'targe170'

! do not lock the collar
!! Collar - Key
!*use,ContactPropMacro.mac,36,'conta174',0,4,mu_all,0e-6,136,'targe170'

! Collar_bot (side) - collar_fil
*use,ContactPropMacro.mac,37,'conta174',0,4,mu_all,0e-6,137,'targe170'

! h-key - iron Yoke
*use,ContactPropMacro.mac,38,'conta174',0,4,mu_all,0e-6,138,'targe170'

! v-key - iron yoke
*use,ContactPropMacro.mac,39,'conta174',0,4,mu_all,0e-6,139,'targe170'

! EPlate - End shoe1
*use,ContactPropMacro.mac,40,'conta174',0,4,mu_all,0e-6,140,'targe170'

! EPlate - End shoe2
*use,ContactPropMacro.mac,41,'conta174',0,4,mu_all,0e-6,141,'targe170'

! End plate - Yoke
*use,ContactPropMacro.mac,42,'conta174',0,1,mu_all,0e-6,142,'targe170'

! End plate - Rod
! bonded the contact to improve the convergency
*use,ContactPropMacro.mac,43,'conta174',5,1,mu_all,0e-6,143,'targe170'

! Rod - nut
*use,ContactPropMacro.mac,44,'conta174',5,1,mu_all,0e-6,144,'targe170'

! ---------------------------------------------------------------------
! Coil - Nose Top - Layer 1
*use,ContactPropMacro.mac,50,'conta174',0,3,mu_all,0e-6,150,'targe170'

! Coil - Nose Fil - Layer 1
*use,ContactPropMacro.mac,51,'conta174',0,3,mu_all,0e-6,151,'targe170'

! Coil - Nose Top - Layer 2
*use,ContactPropMacro.mac,52,'conta174',0,3,mu_all,0e-6,152,'targe170'

! Coil - Nose Fil - Layer 2
*use,ContactPropMacro.mac,53,'conta174',0,3,mu_all,0e-6,153,'targe170'

! ---------------------------------------------------------------------
! Pole - Nose Top
*use,ContactPropMacro.mac,60,'conta174',0,1,mu_all,0e-6,160,'targe170'

! Pole - Nose Fil
*use,ContactPropMacro.mac,61,'conta174',0,1,mu_all,0e-6,161,'targe170'
! ---------------------------------------------------------------------
! Laminated shell
*do,i,1,n_shell-1
 *use,ContactPropMacro.mac,70+i,'conta174',0,1,mu_all,0e-6,170+i,'targe170'
*enddo

! Laminated Pad
*do,i,1,n_pad-1
 *use,ContactPropMacro.mac,200+i,'conta174',0,1,mu_all,0e-6,300+i,'targe170'
*enddo

! Laminated collar top
*do,i,1,n_collar
 *use,ContactPropMacro.mac,220+i,'conta174',0,1,mu_all,0e-6,320+i,'targe170'
*enddo

! Laminated collar ext
*do,i,1,n_collar
 *use,ContactPropMacro.mac,230+i,'conta174',0,1,mu_all,0e-6,330+i,'targe170'
*enddo
! ---------------------------------------------------------------------

! Filler - Collar Top
type,30
real,30
mat ,30

csys,1
! Generate the target surface
cmsel,s,collar_top
alls,below,volu
asel,r,loc,x,r22+tfiller
nsla,s,1
esln,s,0
type,130
esurf,all
alls

! Generate the contact surface
cmsel,s,filler
alls,below,volu
asel,r,loc,x,r22+tfiller
nsla,s,1
esln,s,0
type,30
esurf,all
alls

! -----------------------------------------------------------------
! Collar bot (upper) - collar fil
csys,0
real,31
mat ,31

! Generate the target surface
cmsel,s,collar_bot
allsel,below,volu
*get,ymax,kp,,mxloc,y
asel,r,loc,y,ymax
nsla,r,1
esln,r,0
type,131
esurf,all
allsel

! Generate the contact surface
cmsel,s,collar_fil
allsel,below,volu
asel,r,loc,y,ymax
nsla,r,1
esln,r,0
type,31
esurf,all
allsel

