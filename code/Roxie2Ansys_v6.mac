save,geo,db

! Names - Inner Layer
*do,ll,1,2
! ll = 1
	cmsel,s,layer%ll%
	alls,below,volu
	csys,1
	asel,r,loc,y,90-1e-6,90+1e-6
	*get,anum,area,,count
	cm,atmp_cm,area

	skippo = 1 	! Starting with pole
	cc = 0
	ww = 0
	*do,aa,1,anum
		cmsel,s,atmp_cm
		alls,below,area
		ksel,r,loc,x,r%ll%1
		*get,zmin,kp,,mnloc,z
		ksel,r,loc,z,zmin-1e-6,zmin+1e-6
		lslk,r
		asll,r
		*get,atmp,area,,num,min
		vsla,s
		*if,skippo,eq,0,then
			cc = cc + 1
			cm,coil%ll%%cc%,volu
			skippo = 1
		*elseif,skippo,eq,1,then
			ww = ww + 1
			cm,wedge%ll%%ww-1%,volu
			skippo = 0
		*endif
		! Update cm
		cmsel,s,atmp_cm
		asel,u,area,,atmp
		cm,atmp_cm,area
	*enddo

	! Pole
	cmsel,s,wedge%ll%0
	cm,pole%ll%,volu
	cmdele,wedge%ll%0

	! Endshoe
	cmsel,s,wedge%ll%%ww-1%
	cm,endshoe%ll%,volu
	cmdele,wedge%ll%%ww%

	! Global Names
	vsel,none
	*do,ii,1,cc
		cmsel,a,coil%ll%%ii%
	*enddo
	cm,coil%ll%,volu
	Nc%ll% = cc

	vsel,none
	*do,ii,1,ww-2
		cmsel,a,wedge%ll%%ii%
	*enddo
	cm,wedge%ll%,volu
	Nw%ll% = ww-2

	! Endspacers
	cmsel,s,layer%ll%
	cmsel,u,endshoe%ll%
	alls,below,volu
	asel,r,loc,z,0
	vsla,u
	alls,below,volu
	asel,r,loc,y,90
	*get,anum,area,,count
	cm,atmp_cm,area

	es = 0
	*do,aa,1,anum
		cmsel,s,atmp_cm
		alls,below,area
		ksel,r,loc,x,r%ll%1
		*get,zmin,kp,,mnloc,z
		ksel,r,loc,z,zmin
		lslk,r
		asll,r
		*get,atmp,area,,num,min
		vsla,s
		es = es + 1
		cm,endspacer%ll%%es%,volu

		! Update cm
		cmsel,s,atmp_cm
		asel,u,area,,atmp
		cm,atmp_cm,area
	*enddo

	vsel,none		
	*do,ii,1,es
		cmsel,a,endspacer%ll%%ii%
	*enddo
	cm,endspacer%ll%,volu

*enddo

