eplot

! - Test - Separate the meshes
! cmsel,s,pole1
! alls,below,volu
! vgen,2,all

! Extrude
*if,L_extr,gt,0,then
L_extr = 300
Nlayer = 2

*do,ll,1,Nlayer
	*do,cc,1,Nc%ll%
		cmsel,s,coil%ll%%cc%
		alls,below,volu
		asel,r,loc,z,0
		*get,cura,area,,num,min
		vext,cura,,,0,0,-L_extr
		vsweep,all
		vatt,mat_coil
		cm,coil%ll%%cc%,volu
	*enddo

	*do,ww,1,Nw%ll%
		cmsel,s,wedge%ll%%ww%
		alls,below,volu
		asel,r,loc,z,0
		*get,cura,area,,num,min
		vext,cura,,,0,0,-L_extr
		vatt,mat_albr
		vsweep,all
		cm,wedge%ll%%cc%,volu
	*enddo

	cmsel,s,pole%ll%
	alls,below,volu
	asel,r,loc,z,0
	*get,cura,area,,num,min
	vext,cura,,,0,0,-L_extr
	vatt,mat_albr
	vsweep,all
	cm,pole%ll%%cc%,volu

	! Names
	vsel,none
	*do,cc,1,Nc%ll%
		cmsel,a,coil%ll%%cc%
	*enddo
	cm,coil%ll%,volu

	vsel,none
	*do,cc,1,Nw%ll%
		cmsel,a,wedge%ll%%cc%
	*enddo
	cm,wedge%ll%,volu
	
*enddo

cmsel,s,coil1
cmsel,a,coil2
cm,coil,volu

cmsel,s,wedge1
cmsel,a,wedge2
cm,wedge,volu

alls
/view,,1,1,1
eplot

! Move
alls
vgen,2,all,,,,,L_extr,,,1
eplot

*endif

! - Remove parameters
/output,empty,dat
/output
parres,,empty,dat
! ------------------------------------------------------