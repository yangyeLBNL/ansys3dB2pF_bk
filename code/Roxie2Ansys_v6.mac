asll,r
alls,below,area
asll,s
! ---------------------------------------------
cm,area_cut_ou,area
cmsel,s,area_cut
cmsel,u,area_cut_ou
cm,area_cut_in,area

! Inner Volume
vsel,none
rin = r11
rou = r12

k,,rin,0
k1 = _return
k,,rou,0
k2 = _return
k,,rou,90
k3 = _return
