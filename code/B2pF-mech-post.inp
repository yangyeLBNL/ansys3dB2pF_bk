(1A5,8A10)

rsys,1

! case loop
*do,icase,1,nind
 set,icase

 *do,i,1,2
  *do,j,1,4
   cmsel,s,coil%i%%j%
   vsel,r,loc,z,coil_length-end_length,coil_length
   allsel,below
   plnsol,s,z
   *get,s%i%%j%_max,plnsol,0,min
  *enddo
 *enddo
 
*vwrite,icase,s11_max*1e-6,s12_max*1e-6,s13_max*1e-6,s14_max*1e-6,s21_max*1e-6,s22_max*1e-6,s23_max*1e-6,s24_max*1e-6
